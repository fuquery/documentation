<div class="toolbar" role="navigation">
{{> nav-toggle}}
  {{#with site.homeUrl}}
  <a href="{{{relativize this}}}" class="home-link{{#if @root.page.home}} is-current{{/if}}"></a>
  {{/with}}
{{> breadcrumbs}}
{{> page-versions}}
{{> edit-this-page}}
<button id="darkModeToggle" class="dark-mode-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
  <svg class="dark-mode-icon" viewBox="0 0 24 24" width="1.25rem" height="1.25rem" fill="currentColor">
    <!-- Sun icon (default light mode) -->
    <circle class="sun-circle" cx="12" cy="12" r="5" opacity="1" style="transition: opacity 0.3s ease;"/>
    <g class="sun-rays" opacity="1" style="transition: opacity 0.3s ease;">
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </g>
    <!-- Moon icon (dark mode) -->
    <path class="moon-path" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" opacity="0" style="transition: opacity 0.3s ease;"/>
  </svg>
</button>
</div>

<script>
  const toggle = document.getElementById('darkModeToggle');
  const icon = toggle.querySelector('svg');
  var saved = localStorage.getItem('theme');
  var systemPref = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  var theme = saved === 'dark' || saved === 'light' ? saved : systemPref;

  if (icon) {
    const isDark = theme === 'dark';
    icon.classList.toggle('is-dark', isDark);
  } else {
    console.warn('Dark mode toggle icon not found');
  }

</script>